# ── ET AI TRADER X - ENVIRONMENT TEMPLATE ───────────────
# Copy this file to .env and fill in your keys

# --- PROJECT ---
APP_ENV=development
LOG_LEVEL=INFO
DEFAULT_TIMEZONE=Asia/Kolkata
DEFAULT_MARKET_REGION=IN
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- LLM PROVIDERS (Essential) ---
# OpenAI is the primary provider for RAG and complex reasoning
OPENAI_API_KEY=sk-proj-xxxxxx

# --- LLM PROVIDERS (Optional Fallbacks) ---
GROQ_API_KEY=gsk_xxxxxx
GEMINI_API_KEY=AIxxxxxx
OPENROUTER_API_KEY=sk-or-xxxxxx

# --- MODEL SELECTION ---
MODEL=gpt-4o
GROQ_MODEL=llama3-70b-8192
OPENROUTER_MODEL=anthropic/claude-3-opus

# --- FINANCE & NEWS APIs ---
# Required for radar catalysts and market depth
FINNHUB_API_KEY=xxxxxx
# Required for market news intelligence
NEWS_API_KEY=xxxxxx
# Optional fallback for news
GNEWS_API_KEY=xxxxxx

# --- SUPABASE (Essential) ---
# Used for persistence, chat history, and vector storage
SUPABASE_URL=https://xxxxxx.supabase.co
SUPABASE_ANON_KEY=xxxxxx
SUPABASE_SERVICE_ROLE_KEY=xxxxxx

# --- INFRASTRUCTURE ---
# Local path for LlamaIndex vector persistence
RAG_VECTOR_DB_PATH=storage/vector_indices
# Optional: Redis for high-speed caching
REDIS_URL=redis://localhost:6379/0
